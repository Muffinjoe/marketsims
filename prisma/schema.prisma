generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  password     String
  balance      Float    @default(10000)
  referralCode String   @unique
  referredBy   String?
  streak       Int      @default(0)
  lastPickDate String?
  createdAt    DateTime @default(now())

  positions    Position[]
  transactions Transaction[]
  followers    Follow[]   @relation("following")
  following    Follow[]   @relation("followers")
  activities   Activity[]
}

model Position {
  id          String   @id @default(cuid())
  userId      String
  conditionId String
  marketSlug  String
  question    String
  outcome     String
  shares      Float
  avgPrice    Float
  resolved    Boolean  @default(false)
  won         Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, conditionId, outcome])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  conditionId String?
  marketSlug  String?
  question    String?
  outcome     String?
  shares      Float?
  price       Float?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("followers", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Activity {
  id           String   @id @default(cuid())
  userId       String
  type         String
  conditionId  String?
  marketSlug   String?
  question     String?
  outcome      String?
  shares       Float?
  price        Float?
  sourceUserId String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
